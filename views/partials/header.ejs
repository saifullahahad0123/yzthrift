<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>sfthriftstore</title>

    <link rel="stylesheet" href="/css/style.css">
</head>
<body>


<nav class="sf-navbar">

    <div class="sf-logo">

        <a href="/">
            <img src="/images/sfthriftstore.jpg" alt="Logo">
        </a>

        <div class="sf-brand">
            <h2>SF THRIFT STORE</h2>
            <span>Premium Thrift Fashion</span>
        </div>

    </div>

    <form action="/search" method="GET" class="sf-search">

        <input
        type="text"
        name="query"
        placeholder="Search products..."
        required>

        <button type="submit">
            Search
        </button>

    </form>

    <div class="sf-menu-toggle" onclick="toggleMenu(this)">
        ☰
    </div>

    <ul class="sf-nav-links" id="sf-nav-links">

        <li><a href="/">Home</a></li>

        <li><a href="/products">Shop</a></li>

        <li><a href="/orders">Orders</a></li>

        <li><a href="/cart">Cart</a></li>

        <li><a href="/contact">Contact</a></li>

        <% if(user?.isAdmin){ %>
            <li><a href="/admin">Admin</a></li>
        <% } %>

        <% if(user){ %>

        <li class="sf-profile">

            <a href="#" onclick="toggleProfile(event)">
                👤 <%= user.name.toUpperCase() %>
            </a>

            <ul class="sf-dropdown" id="sfProfileMenu">

                <li><a href="/orders">My Orders</a></li>

                <% if(user.isAdmin){ %>
                    <li><a href="/admin">Admin Panel</a></li>
                <% } %>

                <li><a href="/logout">Logout</a></li>

            </ul>

        </li>

        <% } else { %>

        <li>
            <a class="sf-login-btn" href="/login">
                Login
            </a>
        </li>

        <% } %>

    </ul>

</nav>


<script>
function toggleMenu(btn){

    const menu =
    document.getElementById("sf-nav-links");

    menu.classList.toggle("active");

    btn.innerHTML =
    menu.classList.contains("active")
    ? "✖"
    : "☰";
}

function toggleProfile(e){

    e.preventDefault();

    document
    .getElementById("sfProfileMenu")
    .classList.toggle("show");
}
</script>
</body>
</html>